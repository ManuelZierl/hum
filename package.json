{
  "name": "mchat",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc -p packages/ui-components/tsconfig.json",
    "lint": "eslint 'packages/**/*.{ts,tsx,js}'",
    "format": "prettier --write '**/*.{ts,tsx,js,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,json,md}'",
    "prepare": "husky",
    "test": "jest",
    "build": "pnpm -r --filter './packages/*' build",
    "storybook:start": "npm --prefix apps/storybook start",
    "storybook:dev": "pnpm --dir apps/storybook exec storybook dev -p 6006 --ci",
    "storybook:build": "pnpm --dir apps/storybook exec storybook build -o ../../storybook-static",
    "test:sb:e2e": "playwright test",
    "storybook:ios": "npm --prefix apps/storybook run ios",
    "storybook:android": "npm --prefix apps/storybook run android"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js}": [
      "eslint --cache --fix"
    ]
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "native/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@testing-library/jest-native": "5.4.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.12",
    "@types/react-native": "0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.0.10",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.1.1",
    "@playwright/test": "^1.51.2",
    "start-server-and-test": "^2.0.3",
    "lint-staged": "^16.1.5",
    "prettier": "^3.3.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-native": "0.75.4",
    "react-native-web": "~0.21.1",
    "react-test-renderer": "19.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.15.0",
  "overrides": {
    "metro": "^0.82.5",
    "metro-config": "^0.82.5",
    "metro-resolver": "^0.82.5",
    "metro-cache": "^0.82.5",
    "metro-runtime": "^0.82.5",
    "@expo/metro-config": "^0.20.17"
  },
  "dependencies": {
    "@testing-library/react": "16.3.0"
  },
  "pnpm": {
    "trustedDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
