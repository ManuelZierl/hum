{
  "name": "hum",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npm --prefix apps/mobile start",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint 'packages/**/*.{ts,tsx,js}' 'apps/**/*.{ts,tsx,js}' 'scripts/**/*.cjs' --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,json}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,json}'",
    "lint:md": "remark ./docs --ext .md --frail",
    "lint:md:fix": "remark ./docs --ext .md --frail --output",
    "prepare": "husky",
    "test": "jest --runInBand",
    "build": "npm run -ws --if-present build",
    "sync:version": "node scripts/sync-version.cjs",
    "build-info": "node scripts/gen-build-info.cjs",
    "prebuild": "npm run build-info",
    "storybook:start": "npm --prefix apps/storybook start",
    "storybook:dev": "npm --prefix apps/storybook run dev",
    "storybook:build": "npm --prefix apps/storybook run build",
    "test:sb:e2e": "playwright test",
    "storybook:ios": "npm --prefix apps/storybook run ios",
    "storybook:android": "npm --prefix apps/storybook run android",
    "sb:start": "npm run storybook:start",
    "sb:dev": "npm run storybook:dev",
    "sb:build": "npm run storybook:build",
    "sb:ios": "npm run storybook:ios",
    "sb:android": "npm run storybook:android",
    "i18n:missing": "node scripts/i18n-missing.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "lint-staged": {
    "**/*.{ts,tsx,js}": [
      "bash -lc 'npm run lint'"
    ],
    "**/*.ts?(x)": [
      "bash -lc 'npm run typecheck'"
    ],
    "**/*.{ts,tsx,js,json}": [
      "bash -lc 'npm run format'"
    ],
    "**/*.md": [
      "bash -lc 'npm run lint:md --'"
    ]
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.51.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.1.12",
    "@types/react-native": "0.73.0",
    "@types/react-test-renderer": "19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "http-server": "14.1.1",
    "husky": "^9.0.10",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "^30.1.1",
    "lint-staged": "^16.1.5",
    "nock": "^14.0.10",
    "node-fetch": "^3.3.2",
    "prettier": "^3.3.2",
    "react-native-svg-transformer": "^1.5.1",
    "react-test-renderer": "19.1.0",
    "remark-cli": "^12.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-validate-links": "^13.1.0",
    "start-server-and-test": "^2.0.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-safe-area-context": "5.6.0",
    "@types/react": "^19.1.12"
  },
  "dependencies": {
    "jest-fixed-jsdom": "^0.0.10"
  }
}
