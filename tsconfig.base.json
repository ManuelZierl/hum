{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "paths": {
      "@apps/*": ["apps/*/src"],
      "@packages/*": ["packages/*/src"],
      "@hum/*": ["packages/*/src"],
      "@native/*": ["native/*/src"],
      "@hum/ui-components": ["packages/ui-components/index.ts"],
      "@hum/ui-components/*": ["packages/ui-components/src/*"],
      "@hum/ui-screens": ["packages/ui-screens"],
      "@hum/ui-screens/*": [
        "packages/ui-screens/*",
        "packages/ui-screens/src/*"
      ],
      "@hum/payment-client": ["packages/payment-client/index.ts"],
      "@hum/payment-client/*": ["packages/payment-client/src/*"],
      "@hum/breeze-payment-client": ["packages/breeze-payment-client/index.ts"],
      "@hum/breeze-payment-client/*": ["packages/breeze-payment-client/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
