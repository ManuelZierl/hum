{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@apps/*": ["apps/*/src"],
      "@packages/*": ["packages/*/src"],
      "@mchat/*": ["packages/*/src"],
      "@native/*": ["native/*/src"],
      "@hum/ui-components": ["packages/ui-components"],
      "@hum/ui-components/*": ["packages/ui-components/*"],
      "@hum/ui-screens": ["packages/ui-screens"],
      "@hum/ui-screens/*": ["packages/ui-screens/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
