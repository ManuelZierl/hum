{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "rootDir": "..",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["jest", "react", "react-native"],
    "typeRoots": ["../../tests", "../../node_modules/@types"]
  },
  "include": ["src", "../ui-components/src/**/*", "**/*.ts", "**/*.tsx"],
  "exclude": [
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "../ui-components/src/**/*.test.ts",
    "../ui-components/src/**/*.test.tsx"
  ]
}
