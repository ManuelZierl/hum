[Error]
enum FfiError {
    "Other",
};

interface Client {
    [Throws=FfiError]
    void login(string username, string password);
    [Throws=FfiError]
    void start_sync(boolean sliding);
    [Throws=FfiError]
    void send_text(string room_id, string body);
};

namespace hum {
    [Throws=FfiError]
    Client init(string hs_url, string store_path);
};
