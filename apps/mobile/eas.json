{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "channel": "staging",
      "distribution": "internal",
      "env": {
        "APP_ENV": "staging"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "preview": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./credentials/google-service-account.json"
      },
      "ios": {}
    }
  }
}
