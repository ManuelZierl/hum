{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prestart": "npm --prefix ../.. run build:packages",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "rust:build:android": "bash ../../native/rust/scripts/build-android.sh --out ../../native/rust/build/android --release",
    "rust:build:ios": "bash ../../native/rust/scripts/build-ios.sh --out ../../native/rust/build/ios --release",
    "dev:android": "WITH_HUM_RUST=true HUM_RUST_REPO_ROOT=../../ DEV_FEATURES=1 expo run:android",
    "dev:ios": "WITH_HUM_RUST=true HUM_RUST_IOS_OUT=../../native/rust/build/ios DEV_FEATURES=1 expo run:ios",
    "dev:android:all": "npm run rust:build:android && npm run dev:android",
    "dev:ios:all": "npm run rust:build:ios && npm run dev:ios"
  },
  "dependencies": {
    "@babel/runtime": "7.28.3",
    "@hum/hum-matrix-native": "file:../../packages/hum-matrix-native",
    "@hum/i18n": "file:../../packages/i18n",
    "@hum/ui-components": "file:../../packages/ui-components",
    "@hum/ui-screens": "file:../../packages/ui-screens",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.10",
    "expo-clipboard": "~8.0.7",
    "expo-dev-client": "~6.0.12",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@expo/cli": "54.0.5",
    "babel-preset-expo": "~54.0.0",
    "metro": "^0.83.1",
    "typescript": "~5.9.2"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/hum/hum",
    "directory": "apps/mobile"
  },
  "bugs": {
    "url": "https://github.com/hum/hum/issues"
  },
  "homepage": "https://github.com/hum/hum#readme"
}
